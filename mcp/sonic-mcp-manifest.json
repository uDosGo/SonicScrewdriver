{
  "$schema": "https://spec.modelcontextprotocol.io/schemas/2024-11-05/tool-manifest.json",
  "manifest_version": "1.0.0",
  "server": {
    "name": "SonicScrewdriver",
    "version": "2.0.0",
    "description": "Universal USB Bootloader & System Toolkit MCP tool surface. Hardware-sensitive actions are gated and require explicit confirmation.",
    "repository": "https://github.com/uDosGo/SonicScrewdriver",
    "safety_policy": {
      "description": "SonicScrewdriver tools are classified as safe, caution, or gated. Gated tools require explicit user confirmation for every invocation. Caution tools may prompt once per session. Safe tools are read-only and auto-execute.",
      "classifications": {
        "safe": "Read-only, no side effects. Auto-execute.",
        "caution": "May read system state or create files. Prompt once per session.",
        "gated": "Writes to hardware or filesystem. Confirm every invocation."
      }
    }
  },
  "tools": [
    {
      "name": "sonic.usb.list",
      "description": "List connected USB block devices",
      "safety": "safe",
      "inputSchema": {
        "type": "object",
        "properties": {},
        "required": []
      }
    },
    {
      "name": "sonic.usb.info",
      "description": "Show partition layout and metadata for a USB device",
      "safety": "safe",
      "inputSchema": {
        "type": "object",
        "properties": {
          "device": { "type": "string", "description": "Block device path (e.g., /dev/sdb)" }
        },
        "required": ["device"]
      }
    },
    {
      "name": "sonic.usb.create",
      "description": "Create triple-partition Sonic USB drive (ESP + ext4 + exFAT). DESTRUCTIVE — wipes target device.",
      "safety": "gated",
      "inputSchema": {
        "type": "object",
        "properties": {
          "device": { "type": "string", "description": "Block device path" },
          "force": { "type": "boolean", "description": "Skip confirmation", "default": false },
          "label": { "type": "string", "description": "exFAT partition label", "default": "SONIC" },
          "macos_installer": { "type": "string", "description": "Path to macOS installer app" },
          "linux_iso": { "type": "string", "description": "Path to customized Linux Mint ISO" },
          "recovery_dir": { "type": "string", "description": "Path to recovery tools directory" }
        },
        "required": ["device"]
      }
    },
    {
      "name": "sonic.usb.destroy",
      "description": "Wipe Sonic partitions and restore single volume. DESTRUCTIVE.",
      "safety": "gated",
      "inputSchema": {
        "type": "object",
        "properties": {
          "device": { "type": "string", "description": "Block device path" },
          "force": { "type": "boolean", "description": "Skip confirmation", "default": false }
        },
        "required": ["device"]
      }
    },
    {
      "name": "sonic.security.enroll",
      "description": "Enroll FIDO2/GPG/SSH/TPM security device",
      "safety": "gated",
      "inputSchema": {
        "type": "object",
        "properties": {
          "dev_type": { "type": "string", "enum": ["auto", "fido2", "gpg", "ssh", "tpm"], "default": "auto" },
          "label": { "type": "string" },
          "pin": { "type": "string", "description": "PIN for FIDO2 devices" }
        },
        "required": []
      }
    },
    {
      "name": "sonic.security.list",
      "description": "List enrolled security devices",
      "safety": "safe",
      "inputSchema": { "type": "object", "properties": {}, "required": [] }
    },
    {
      "name": "sonic.security.revoke",
      "description": "Revoke an enrolled security device. Irreversible.",
      "safety": "gated",
      "inputSchema": {
        "type": "object",
        "properties": {
          "device_id": { "type": "string" }
        },
        "required": ["device_id"]
      }
    },
    {
      "name": "sonic.security.generate-ssh",
      "description": "Generate Sonic SSH key pair (ed25519/rsa/ecdsa)",
      "safety": "caution",
      "inputSchema": {
        "type": "object",
        "properties": {
          "output": { "type": "string", "default": "~/.ssh/id_sonic" },
          "key_type": { "type": "string", "enum": ["ed25519", "rsa", "ecdsa"], "default": "ed25519" }
        },
        "required": []
      }
    },
    {
      "name": "sonic.security.generate-gpg",
      "description": "Generate Sonic GPG key pair",
      "safety": "caution",
      "inputSchema": {
        "type": "object",
        "properties": {
          "output": { "type": "string", "default": "~/.gnupg/sonic.gpg" },
          "name": { "type": "string" },
          "email": { "type": "string" }
        },
        "required": []
      }
    },
    {
      "name": "sonic.mint.build",
      "description": "Customize Linux Mint ISO with uDos/Sonic configuration",
      "safety": "caution",
      "inputSchema": {
        "type": "object",
        "properties": {
          "input_iso": { "type": "string" },
          "output_iso": { "type": "string" },
          "hostname": { "type": "string", "default": "sonic-mint" },
          "username": { "type": "string", "default": "sonic" },
          "password": { "type": "string" },
          "timezone": { "type": "string", "default": "Australia/Brisbane" },
          "desktop": { "type": "string", "enum": ["cinnamon", "xfce", "mate"], "default": "cinnamon" },
          "branding": { "type": "boolean", "default": false },
          "preinstall_sonic": { "type": "boolean", "default": false }
        },
        "required": ["input_iso", "output_iso"]
      }
    },
    {
      "name": "sonic.mint.verify",
      "description": "Verify Linux Mint ISO checksum integrity",
      "safety": "safe",
      "inputSchema": {
        "type": "object",
        "properties": {
          "iso_path": { "type": "string" }
        },
        "required": ["iso_path"]
      }
    },
    {
      "name": "sonic.mint.preseed",
      "description": "Extract preseed configuration from customized ISO",
      "safety": "safe",
      "inputSchema": {
        "type": "object",
        "properties": {
          "iso_path": { "type": "string" },
          "output": { "type": "string", "default": "sonic-mint-preseed.cfg" }
        },
        "required": ["iso_path"]
      }
    },
    {
      "name": "sonic.bootloader.install",
      "description": "Install SonicScrewloader to USB drive ESP. Writes to device.",
      "safety": "gated",
      "inputSchema": {
        "type": "object",
        "properties": {
          "device": { "type": "string" },
          "efi_path": { "type": "string", "default": "\\EFI\\sonic" },
          "config": { "type": "string", "description": "Custom menu YAML config path" },
          "theme": { "type": "string", "description": "Custom theme YAML config path" },
          "force": { "type": "boolean", "default": false }
        },
        "required": ["device"]
      }
    },
    {
      "name": "sonic.bootloader.status",
      "description": "Check SonicScrewloader installation health on a device",
      "safety": "safe",
      "inputSchema": {
        "type": "object",
        "properties": {
          "device": { "type": "string" }
        },
        "required": ["device"]
      }
    },
    {
      "name": "sonic.bootloader.remove",
      "description": "Remove SonicScrewloader from device. Destructive.",
      "safety": "gated",
      "inputSchema": {
        "type": "object",
        "properties": {
          "device": { "type": "string" },
          "force": { "type": "boolean", "default": false }
        },
        "required": ["device"]
      }
    },
    {
      "name": "sonic.bootloader.build",
      "description": "Cross-compile bootloader binary (UEFI x86_64/aarch64, BIOS). Requires gnu-efi toolchain.",
      "safety": "caution",
      "inputSchema": {
        "type": "object",
        "properties": {
          "output": { "type": "string", "default": "sonic-bootloader.efi" },
          "arch": { "type": "string", "enum": ["x86_64", "aarch64"], "default": "x86_64" },
          "bios": { "type": "boolean", "default": false }
        },
        "required": []
      }
    },
    {
      "name": "sonic.bootloader.test",
      "description": "Test bootloader in QEMU emulator. Read-only, emulated.",
      "safety": "safe",
      "inputSchema": {
        "type": "object",
        "properties": {
          "uefi": { "type": "boolean", "default": false },
          "bios": { "type": "boolean", "default": false },
          "efi_binary": { "type": "string", "default": "sonic-bootloader.efi" },
          "bios_binary": { "type": "string", "default": "sonic-bootloader.bin" }
        },
        "required": []
      }
    },
    {
      "name": "sonic.device.scan",
      "description": "Scan for connected devices (USB, PCI, Bluetooth)",
      "safety": "safe",
      "inputSchema": {
        "type": "object",
        "properties": {
          "timeout": { "type": "integer", "default": 5 }
        },
        "required": []
      }
    },
    {
      "name": "sonic.device.identify",
      "description": "Identify hardware capabilities of a device",
      "safety": "safe",
      "inputSchema": {
        "type": "object",
        "properties": {
          "device_id": { "type": "string" }
        },
        "required": ["device_id"]
      }
    },
    {
      "name": "sonic.device.lookup",
      "description": "Query local device database",
      "safety": "safe",
      "inputSchema": {
        "type": "object",
        "properties": {
          "query": { "type": "string" }
        },
        "required": ["query"]
      }
    },
    {
      "name": "sonic.device.add",
      "description": "Add custom device entry to local database",
      "safety": "safe",
      "inputSchema": {
        "type": "object",
        "properties": {
          "device_id": { "type": "string" },
          "vendor": { "type": "string" },
          "model": { "type": "string" },
          "dev_type": { "type": "string", "enum": ["pc", "laptop", "router", "esp32", "phone", "other"] },
          "capabilities": { "type": "string" }
        },
        "required": ["device_id"]
      }
    },
    {
      "name": "sonic.device.remove",
      "description": "Remove device entry from local database",
      "safety": "safe",
      "inputSchema": {
        "type": "object",
        "properties": {
          "device_id": { "type": "string" },
          "force": { "type": "boolean", "default": false }
        },
        "required": ["device_id"]
      }
    },
    {
      "name": "sonic.device.repurpose",
      "description": "Repurpose router/device (beacon, OpenWrt, mesh). May flash firmware.",
      "safety": "gated",
      "inputSchema": {
        "type": "object",
        "properties": {
          "device_id": { "type": "string" },
          "mode": { "type": "string", "enum": ["beacon", "openwrt", "mesh"], "default": "beacon" },
          "firmware": { "type": "string" },
          "force": { "type": "boolean", "default": false }
        },
        "required": ["device_id"]
      }
    },
    {
      "name": "sonic.device.flash",
      "description": "Flash firmware to ESP32/router via serial. Destructive.",
      "safety": "gated",
      "inputSchema": {
        "type": "object",
        "properties": {
          "device_id": { "type": "string" },
          "firmware": { "type": "string" },
          "port": { "type": "string", "description": "Serial port (auto-detect if omitted)" },
          "baud": { "type": "integer", "default": 115200 },
          "force": { "type": "boolean", "default": false }
        },
        "required": ["device_id", "firmware"]
      }
    },
    {
      "name": "sonic.device.ewaste",
      "description": "Classify device for e-waste disposal with guidance",
      "safety": "safe",
      "inputSchema": {
        "type": "object",
        "properties": {
          "device_id": { "type": "string" },
          "force": { "type": "boolean", "default": false }
        },
        "required": ["device_id"]
      }
    },
    {
      "name": "sonic.device.submit",
      "description": "Submit device to global Sonic registry via network POST",
      "safety": "caution",
      "inputSchema": {
        "type": "object",
        "properties": {
          "device_id": { "type": "string" },
          "registry": { "type": "string", "default": "https://registry.sonic.sh/v1/devices" }
        },
        "required": ["device_id"]
      }
    },
    {
      "name": "sonic.diagnostics.summary",
      "description": "Show recent spool event summary (last N events, failures, warnings)",
      "safety": "safe",
      "inputSchema": {
        "type": "object",
        "properties": {
          "limit": { "type": "integer", "default": 50 }
        },
        "required": []
      }
    },
    {
      "name": "sonic.diagnostics.health",
      "description": "Full system health check across USB, bootloader, and device database",
      "safety": "safe",
      "inputSchema": {
        "type": "object",
        "properties": {},
        "required": []
      }
    }
  ]
}